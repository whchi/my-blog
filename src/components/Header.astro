---
const navItems = [
  { href: "/about/", label: "About" },
  { href: "/tags/", label: "Tags" },
  { href: "/archives/", label: "Archives" },
  { href: "/tools/", label: "Tools" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="site-header">
  <a class="brand" href="/" aria-label="社畜人生首頁">社畜人生</a>
  <nav class="site-nav" aria-label="主選單">
    {navItems.map((item) => (
      <a
        href={item.href}
        aria-current={currentPath.startsWith(item.href.replace(/\/$/, "")) ? "page" : undefined}
      >
        {item.label}
      </a>
    ))}
  </nav>
  <div class="header-actions">
    <button class="icon-button" data-search-open aria-label="搜尋">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21 21-4.3-4.3m1.3-5.2a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z" /></svg>
    </button>
    <button class="icon-button" data-theme-toggle aria-label="切換深色模式">
      <svg viewBox="0 0 24 24" aria-hidden="true" class="theme-icon-moon"><path d="M12 3a9 9 0 1 0 9 9 7 7 0 0 1-9-9Z" /></svg>
      <svg viewBox="0 0 24 24" aria-hidden="true" class="theme-icon-sun" style="display:none"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32l1.41-1.41"/></svg>
    </button>
  </div>
</header>
