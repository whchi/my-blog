---
const workStages = [
  // {
  //   period: "2026/01 - 現在",
  //   title: "票務平台",
  //   role: "合約工程師",
  //   summary:
  //     "投入票務交易與上線可靠性，處理訂單、鎖票、資料轉移、waiting room、壓測與 observability 等 production 議題。",
  // },
  {
    period: "2024/07 - 現在",
    title: "Docubank 大庫辦",
    role: "解決方案工程師",
    summary:
      "將企業文件流程與 AI 應用從 POC 推進到可部署、可維運的產品階段，涵蓋 RAG、資料匯入、離線環境與多租戶權限。",
  },
  {
    period: "2022/09 - 2024/06",
    title: "CYBERBIZ",
    role: "主任工程師",
    summary:
      "負責電商平台擴充、APP Market 架構與企業客製交付，並帶領小組支援大型商家需求與高流量活動。",
  },
  {
    period: "2020/12 - 2022/06",
    title: "奧丁丁集團",
    role: "研發工程師",
    summary:
      "在區塊鏈實驗室參與 IoT Gateway、NFT Marketplace 與供應鏈追溯系統，負責產品開發、串接與 production 維運。",
  },
  {
    period: "2018/11 - 2020/12",
    title: "天下雜誌",
    role: "資深工程師",
    summary:
      "支援媒體產品工程，涵蓋活動型系統、內容工具、資料流程、使用者標籤與 AI 推薦服務產品化。",
  },
  {
    period: "2014/04 - 2018/11",
    title: "早期經歷",
    role: "工程師",
    summary:
      "從政府平台、客戶導入、電商後端、API 串接與早期 IoT / 後台系統開始累積產品交付與維運經驗。",
  },
];

const focusItems = [
  "把 AI 應用做成能上線與維運的產品",
  "設計能承受真實流量與資料狀態的後端流程",
  "建立團隊能接手、能排錯、能持續演進的系統",
];
---

<section class="about-profile">
  <div class="profile-panel">
    <div class="profile-border">
      <div class="profile-avatar">
        <img
          src="https://avatars.githubusercontent.com/u/11798731?v=4"
          alt="whchi 的個人照片"
          loading="lazy"
          width="150"
          height="150"
        />
      </div>
    </div>
    <div class="profile-info">
      <p class="profile-kicker">Practical SWE</p>
      <h2 class="profile-name">whchi</h2>
      <p class="profile-tagline">
        AI Application · Backend · Production Observability
      </p>
      <a class="profile-email" href="mailto:whccchi@gmail.com">whccchi@gmail.com</a>
    </div>
    <nav class="profile-links" aria-label="個人連結">
      <ul>
        <li>
          <a href="https://github.com/whchi" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.133-3.369-1.133-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.308.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/>
            </svg>
            github
          </a>
        </li>
        <li>
          <a href="https://medium.com/@whccchi" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zM20.96 12c0 3.76-1.68 6.8-3.75 6.8s-3.74-3.04-3.74-6.8c0-3.76 1.67-6.8 3.74-6.8s3.75 3.04 3.75 6.8zM24 12c0 3.37-.56 6.1-1.25 6.1s-1.25-2.73-1.25-6.1c0-3.37.56-6.1 1.25-6.1s1.25 2.73 1.25 6.1z"/>
            </svg>
            medium
          </a>
        </li>
        <li>
          <a href="https://www.linkedin.com/in/wei-han-chi-615006110/" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            linkedin
          </a>
        </li>
      </ul>
    </nav>
  </div>

  <div class="experience-panel" aria-labelledby="experience-title">
    <div class="experience-heading">
      <p class="experience-kicker">經歷摘錄</p>
      <h2 id="experience-title">工作階段</h2>
    </div>
    <ol class="work-timeline">
      {workStages.map((stage) => (
        <li class="work-stage">
          <div class="stage-marker" aria-hidden="true"></div>
          <div class="stage-content">
            <div class="stage-meta">
              <p class="stage-period">{stage.period}</p>
              <p class="stage-role">{stage.role}</p>
            </div>
            <h3>{stage.title}</h3>
            <p class="stage-summary">{stage.summary}</p>
          </div>
        </li>
      ))}
    </ol>
    <section class="current-focus" aria-labelledby="current-focus-title">
      <p class="experience-kicker">現在適合投入</p>
      <h3 id="current-focus-title">目前關注</h3>
      <ul>
        {focusItems.map((item) => <li>{item}</li>)}
      </ul>
    </section>
  </div>
</section>

<style>
  .about-profile {
    display: grid;
    grid-template-columns: minmax(220px, 0.8fr) minmax(0, 1.5fr);
    gap: clamp(1.25rem, 4vw, 2.5rem);
    align-items: start;
    margin-bottom: 3rem;
  }

  .profile-panel,
  .experience-panel {
    position: relative;
    isolation: isolate;
    border: 1px solid color-mix(in srgb, var(--line), var(--surface) 35%);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface), white 10%), var(--surface)),
      var(--surface);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white, transparent 20%),
      0 24px 70px color-mix(in srgb, var(--text-strong), transparent 92%);
  }

  .profile-panel::before,
  .experience-panel::before {
    content: "";
    position: absolute;
    inset: 0.45rem;
    border: 1px solid var(--line-subtle);
    border-radius: inherit;
    pointer-events: none;
    z-index: -1;
  }

  .profile-panel {
    position: sticky;
    top: 5.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: clamp(1.75rem, 4vw, 2.25rem);
    border-radius: 18px;
    text-align: center;
  }

  .profile-border {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 155px;
    height: 155px;
    border-radius: 50%;
    overflow: hidden;
    background:
      conic-gradient(from 150deg, var(--line), var(--accent), var(--line) 44%, var(--line-subtle)),
      var(--line);
    box-shadow:
      0 0 0 7px color-mix(in srgb, var(--surface-muted), transparent 30%),
      0 18px 40px color-mix(in srgb, var(--accent), transparent 84%);
    transition: transform 520ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .profile-panel:hover .profile-border {
    transform: translateY(-2px) rotate(3deg);
  }

  .profile-avatar {
    border-radius: 50%;
    overflow: hidden;
    width: 150px;
    height: 150px;
    z-index: 1;
    background: var(--bg);
  }

  .profile-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-kicker,
  .experience-kicker {
    margin: 0;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .stage-period,
  .stage-role {
    margin: 0;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 650;
    letter-spacing: 0;
  }

  .profile-name {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 5vw, 2.1rem);
    line-height: 1.1;
    font-weight: 700;
    color: var(--text-strong);
    margin: 0.35rem 0;
  }

  .profile-tagline {
    max-width: 18rem;
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .profile-email {
    display: inline-block;
    margin-top: 0.75rem;
    color: var(--accent-text);
    font-size: 0.92rem;
    font-weight: 600;
    text-decoration: none;
    word-break: break-word;
  }

  .profile-email:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .profile-links ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .profile-links li {
    display: flex;
  }

  .profile-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--line), transparent 15%);
    background: color-mix(in srgb, var(--surface-muted), transparent 20%);
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 500;
    text-decoration: none;
    transition:
      border-color 420ms cubic-bezier(0.22, 1, 0.36, 1),
      background 420ms cubic-bezier(0.22, 1, 0.36, 1),
      color 420ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .profile-links a:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--accent);
    transform: translateY(-1px);
  }

  .profile-links a svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .experience-panel {
    border-radius: 18px;
    padding: clamp(1.5rem, 4vw, 2.25rem);
  }

  .experience-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--line);
  }

  .experience-heading h2 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 4vw, 2.35rem);
    line-height: 1.1;
    color: var(--text-strong);
  }

  .work-timeline {
    position: relative;
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .work-timeline::before {
    content: "";
    position: absolute;
    top: 1.5rem;
    bottom: 1.5rem;
    left: 0.43rem;
    width: 1px;
    background: linear-gradient(180deg, transparent, var(--line), transparent);
  }

  .work-stage {
    position: relative;
    display: grid;
    grid-template-columns: 1.1rem minmax(0, 1fr);
    gap: 1rem;
    padding: 1.4rem 0;
  }

  .work-stage + .work-stage {
    border-top: 1px solid var(--line-subtle);
  }

  .stage-marker {
    width: 0.85rem;
    height: 0.85rem;
    margin-top: 0.35rem;
    border: 2px solid var(--accent);
    border-radius: 50%;
    background: var(--surface);
    box-shadow:
      0 0 0 5px var(--surface),
      0 0 0 6px var(--line-subtle);
    z-index: 1;
  }

  .stage-content {
    min-width: 0;
  }

  .stage-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .stage-role::before {
    content: "/";
    margin-right: 0.5rem;
    color: var(--line);
  }

  .stage-content h3 {
    margin: 0.25rem 0 0;
    font-family: var(--font-serif);
    font-size: clamp(1.12rem, 2.8vw, 1.45rem);
    line-height: 1.25;
    color: var(--text-strong);
  }

  .stage-summary {
    margin: 0.7rem 0 0;
    color: var(--text);
    line-height: 1.75;
  }

  .current-focus {
    margin-top: 0.75rem;
    padding: 1.25rem;
    border: 1px solid color-mix(in srgb, var(--accent), transparent 70%);
    border-radius: 14px;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--accent-soft), transparent 12%), transparent 72%),
      color-mix(in srgb, var(--surface-muted), transparent 15%);
  }

  .current-focus h3 {
    margin: 0.25rem 0 0.85rem;
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--text-strong);
  }

  .current-focus ul {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .current-focus li {
    position: relative;
    padding-left: 1rem;
    color: var(--text);
    line-height: 1.65;
  }

  .current-focus li::before {
    content: "";
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .profile-border,
    .profile-links a {
      transition: none;
    }

    .profile-panel:hover .profile-border,
    .profile-links a:hover {
      transform: none;
    }
  }

  @media (max-width: 820px) {
    .about-profile {
      grid-template-columns: 1fr;
    }

    .profile-panel {
      position: static;
    }
  }

  @media (max-width: 560px) {
    .about-profile {
      margin-bottom: 2rem;
    }

    .profile-panel,
    .experience-panel {
      padding: 1.25rem;
      border-radius: 14px;
    }

    .experience-heading {
      display: block;
    }

    .experience-heading h2 {
      margin-top: 0.2rem;
    }

    .work-stage {
      gap: 0.8rem;
    }
  }
</style>
