---
const { id } = Astro.props;
const src = `https://docs.google.com/presentation/d/e/${id}/embed?start=false&loop=false&delayms=3000`;
---

<div class="gppt-wrapper">
  <iframe
    src={src}
    loading="lazy"
    allowfullscreen
    referrerpolicy="no-referrer-when-downgrade"
  />
</div>

<style>
  .gppt-wrapper {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    height: 0;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--line);
  }

  .gppt-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
