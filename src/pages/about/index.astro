---
import { render } from "astro:content";
import AboutProfile from "../../components/AboutProfile.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageById } from "../../lib/content.js";

const page = await getPageById("about");
if (!page) throw new Error("content/about.md is missing");
const { Content } = await render(page);
---

<BaseLayout title="About" canonical="/about/">
  <AboutProfile />
  <article class="article-shell">
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
