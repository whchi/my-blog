---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPageById } from "../../lib/content.js";

const page = await getPageById("tools");
if (!page) throw new Error("content/tools.md is missing");
const { Content } = await render(page);
---

<BaseLayout title="Tools" canonical="/tools/">
  <article class="article-shell">
    <header class="article-header">
      <p class="eyebrow">Tools</p>
      <h1>Tools</h1>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
