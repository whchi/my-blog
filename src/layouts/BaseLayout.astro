---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SearchOverlay from "../components/SearchOverlay.astro";
import "../styles/site.css";

const {
  title = "社畜人生",
  description = "技術筆記、工具與一些工程現場的碎念。",
  canonical,
  image,
} = Astro.props;

const pageTitle = title === "社畜人生" ? title : `${title} | 社畜人生`;
const canonicalUrl = canonical ? new URL(canonical, Astro.site) : Astro.url;
const ogImage = new URL(image || "/og.png", Astro.site);
const GTM_ID = "GTM-N2DN7CD";
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <script is:inline define:vars={{GTM_ID}}>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer',GTM_ID);</script>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title="社畜人生 RSS" href="/rss.xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{pageTitle}</title>
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme = savedTheme || (prefersDark ? "dark" : "light");
    </script>
  </head>
  <body>
    <div class="night-sky" aria-hidden="true"></div>
    <noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`} height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <Header />
    <SearchOverlay />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      function updateThemeIcons() {
        const isDark = document.documentElement.dataset.theme === "dark";
        document.querySelectorAll(".theme-icon-moon").forEach((el) => el.style.display = isDark ? "none" : "");
        document.querySelectorAll(".theme-icon-sun").forEach((el) => el.style.display = isDark ? "" : "none");
      }
      updateThemeIcons();
      document.querySelector("[data-theme-toggle]")?.addEventListener("click", () => {
        const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("theme", next);
        updateThemeIcons();
      });

      const nightSky = document.querySelector(".night-sky");
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      function randomBetween(min, max) {
        return min + Math.random() * (max - min);
      }
      function createMeteor({top, left, oneShot = false} = {}) {
        const meteor = document.createElement("span");
        meteor.className = oneShot ? "meteor meteor-once" : "meteor";
        meteor.style.setProperty("--meteor-top", top || `${randomBetween(5, 72)}vh`);
        meteor.style.setProperty("--meteor-left", left || `${randomBetween(92, 118)}vw`);
        meteor.style.setProperty("--meteor-width", `${randomBetween(7, 14)}rem`);
        meteor.style.setProperty("--meteor-delay", oneShot ? "0s" : `${randomBetween(0, 11)}s`);
        meteor.style.setProperty("--meteor-duration", `${randomBetween(7, 14)}s`);
        meteor.style.setProperty("--meteor-x", `${randomBetween(-95, -145)}vw`);
        meteor.style.setProperty("--meteor-y", `${randomBetween(34, 68)}vw`);
        return meteor;
      }
      function renderNightSky() {
        if (!nightSky) return;
        const area = window.innerWidth * window.innerHeight;
        const starCount = Math.round(Math.min(220, Math.max(90, area / randomBetween(5200, 8200))));
        const meteorCount = reducedMotion.matches ? 0 : Math.round(randomBetween(3, 7));
        const fragment = document.createDocumentFragment();

        for (let i = 0; i < starCount; i += 1) {
          const star = document.createElement("span");
          star.className = "star";
          star.style.setProperty("--star-x", `${randomBetween(0, 100)}vw`);
          star.style.setProperty("--star-y", `${randomBetween(0, 100)}vh`);
          star.style.setProperty("--star-size", `${randomBetween(0.7, 2.2)}px`);
          star.style.setProperty("--star-opacity", randomBetween(0.28, 0.92).toFixed(2));
          star.style.setProperty("--twinkle-duration", `${randomBetween(4, 11)}s`);
          star.style.setProperty("--twinkle-delay", `${randomBetween(-10, 0)}s`);
          fragment.append(star);
        }

        for (let i = 0; i < meteorCount; i += 1) {
          fragment.append(createMeteor());
        }

        nightSky.replaceChildren(fragment);
      }
      function shootMeteor(event) {
        event.stopPropagation();
        event.stopImmediatePropagation();
        if (!nightSky || reducedMotion.matches || document.documentElement.dataset.theme !== "dark") return;

        const meteor = createMeteor({
          top: `${event.clientY}px`,
          left: `${event.clientX}px`,
          oneShot: true,
        });
        meteor.addEventListener("animationend", () => meteor.remove(), {once: true});
        nightSky.append(meteor);
      }

      renderNightSky();
      nightSky?.addEventListener("click", shootMeteor, true);
      window.addEventListener("resize", renderNightSky);
      reducedMotion.addEventListener("change", renderNightSky);
    </script>
  </body>
</html>
